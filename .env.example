# Database
# Local development
DATABASE_URL="postgresql://user:password@localhost:5432/hrlite?schema=public"
# Neon (production) - pooled connection
# DATABASE_URL="postgresql://...@ep-xxx-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"
# Neon (production) - direct connection (for migrations)
# DIRECT_URL="postgresql://...@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"

# Firebase Client (public — exposed to browser)
NEXT_PUBLIC_FIREBASE_API_KEY="AIza..."
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project-id"

# Firebase Admin (private — server-side only)
FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Session
SESSION_COOKIE_MAX_AGE=432000  # 5 days in seconds

# Application
NODE_ENV="development"
PORT=3000
